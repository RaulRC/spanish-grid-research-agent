# Anthropic API key. Required. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Command to launch the spanish-grid-mcp server. The agent runs this as a
# subprocess and talks to it over stdio.
# Default assumes spanish-grid-mcp is installed in the same Python env.
MCP_SERVER_CMD=python -m spanish_grid_mcp.server

# Model. Defaults to claude-opus-4-7. Override to claude-sonnet-4-6 for a
# cheaper / faster (but less capable) loop.
AGENT_MODEL=claude-opus-4-7

# Hard ceiling on agent loop iterations (safety net).
AGENT_MAX_STEPS=20

# Tokens needed by the MCP server (passed through as env vars when spawned).
ESIOS_TOKEN=
AEMET_TOKEN=
